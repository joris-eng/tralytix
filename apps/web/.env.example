# Server-only runtime variable for the Next.js proxy route.
# Local dev:
API_BASE_URL=http://localhost:8080
# Render web service:
# API_BASE_URL=https://tralytix-api.onrender.com
# Keep backend URL server-only.
# If NEXT_PUBLIC_API_BASE_URL exists in your Render env, remove it.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
